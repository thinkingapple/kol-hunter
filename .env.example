# KOL Hunter Configuration

# Email Provider: gmail, sendgrid, mailgun
EMAIL_PROVIDER=gmail

# Gmail SMTP
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# SendGrid
SENDGRID_API_KEY=

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Sender Identity
SENDER_NAME=Market Team
SENDER_TITLE=Partnership Manager
SENDER_EMAIL=your-email@gmail.com

# Twitter/X (optional, for twikit)
X_USERNAME=
X_PASSWORD=
X_EMAIL=

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///data/kol_hunter.db
SECRET_KEY=change-this-to-a-random-string
